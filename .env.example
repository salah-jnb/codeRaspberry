# =========================================
# KODA Raspberry Pi - environment overrides
# Copy to `.env` and adjust to your wiring.
# =========================================

# --- Robot identity & logging ---
ROBOT_ID=koda-01
LOG_LEVEL=INFO

# --- Backend (FastAPI distributeur on the PC) ---
# Prefer the mDNS hostname over a raw IP so the link survives DHCP changes.
BACKEND_URL=http://SALAH_DESKTOP.local:8765
BACKEND_TIMEOUT=60
# Leave BACKEND_VOICE_NAME empty to let the backend pick from setting.langue.
# BACKEND_VOICE_NAME=ar-SA-HamedNeural
# Optional context appended in parentheses after the STT result (e.g., user name).
# BACKEND_EXTRA_TEXT=salah

# --- ReSpeaker 4-Mic Array (USB capture) ---
RESPEAKER_DEVICE=plughw:3,0
RESPEAKER_SAMPLE_RATE=16000
RESPEAKER_CHANNELS=1
RESPEAKER_SAMPLE_FORMAT=S16_LE
RESPEAKER_RECORD_SECONDS=5
# Substring used by mic_check to confirm device identity (case-insensitive).
RESPEAKER_KEYWORD=respeaker

# --- Bluetooth speaker (output) ---
BLUETOOTH_MAC=CB:7A:DB:AD:30:D9
BLUETOOTH_AUTO_CONNECT=1
# Optional PipeWire/Pulse sink name override (otherwise default sink is used).
# PULSE_SINK=bluez_output.CB_7A_DB_AD_30_D9.a2dp-sink

# --- Nextion display (UART, pins 8/10) ---
NEXTION_PORT=/dev/serial0
NEXTION_BAUDRATE=9600
NEXTION_TIMEOUT=1
NEXTION_REQUIRE_GPIO_UART=1

# --- Arduino UNO + L293D (USB) ---
# Leave ARDUINO_PORT empty to auto-detect /dev/ttyUSB* or /dev/ttyACM*.
# ARDUINO_PORT=/dev/ttyUSB0
ARDUINO_BAUDRATE=9600
ARDUINO_TIMEOUT=2
ARDUINO_BOOT_DELAY=2

# --- Conversation loop ---
LISTEN_SECONDS=5
INTER_TURN_PAUSE=0.5
GESTURE_DURING_SPEECH=1
