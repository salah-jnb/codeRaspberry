# =========================================
# KODA Raspberry Pi - environment overrides
# Copy to `.env` and adjust to your wiring.
# =========================================

# --- Robot identity & logging ---
ROBOT_ID=koda-01
LOG_LEVEL=INFO

# --- Backend (FastAPI distributeur on the PC) ---
# Prefer the mDNS hostname over a raw IP so the link survives DHCP changes.
BACKEND_URL=http://SALAH_DESKTOP.local:8765
BACKEND_TIMEOUT=60
# Leave BACKEND_VOICE_NAME empty to let the backend pick from setting.langue.
# BACKEND_VOICE_NAME=ar-SA-HamedNeural
# Optional context appended in parentheses after the STT result (e.g., user name).
# BACKEND_EXTRA_TEXT=salah

# --- ReSpeaker 4-Mic Array (USB capture) ---
# IMPORTANT: use `pipewire`, NOT `plughw:3,0` directly.
# The ReSpeaker USB firmware rejects ALSA set_freq at 16kHz when opened raw,
# which triggers a device-disconnect loop on every arecord reopen. Going
# through pipewire-alsa fixes it and survives chunked captures.
# Requirements on the Pi: `sudo apt install pipewire pipewire-alsa wireplumber`
# and confirm `arecord -D pipewire -d 1 test.wav` works before running KODA.
RESPEAKER_DEVICE=pipewire
RESPEAKER_SAMPLE_RATE=16000
RESPEAKER_CHANNELS=1
RESPEAKER_SAMPLE_FORMAT=S16_LE
RESPEAKER_RECORD_SECONDS=5
# Substring used by mic_check to confirm device identity (case-insensitive).
RESPEAKER_KEYWORD=respeaker

# --- Bluetooth speaker (output) ---
BLUETOOTH_MAC=AD:1C:99:E7:9B:78
BLUETOOTH_AUTO_CONNECT=1
# Optional PipeWire/Pulse sink name override (otherwise default sink is used).
# PULSE_SINK=bluez_output.AD_1C_99_E7_9B_78.a2dp-sink

# --- Nextion display (UART, pins 8/10) ---
NEXTION_PORT=/dev/serial0
NEXTION_BAUDRATE=9600
NEXTION_TIMEOUT=1
NEXTION_REQUIRE_GPIO_UART=1

# --- Arduino UNO + L293D (USB) ---
# Leave ARDUINO_PORT empty to auto-detect /dev/ttyUSB* or /dev/ttyACM*.
# ARDUINO_PORT=/dev/ttyUSB0
ARDUINO_BAUDRATE=9600
ARDUINO_TIMEOUT=2
ARDUINO_BOOT_DELAY=2
# Set to 1 only if the Arduino sketch sends an ACK line for every command.
ARDUINO_REQUIRE_ACK=0

# --- Conversation loop ---
LISTEN_SECONDS=5
INTER_TURN_PAUSE=0.5
GESTURE_DURING_SPEECH=1
# Number of silent active turns before falling back to passive mode.
MAX_ACTIVE_SILENCES=3
# Phrase parlée juste après détection du wake-word, avant l'écoute de la question.
GREETING_TEXT=أهلا بيك

# --- Wake word (passive listening) ---
# Set to 0 to disable wake word and always-listen.
WAKE_WORD_ENABLED=1
# Comma-separated overrides; leave empty to use the built-in "Mohsen" variants.
# WAKE_WORD_KEYWORDS=محسن,mohsen,koda
# Set to 1 to also fetch dynamic name variants from /api/keywords/robot-name.
WAKE_WORD_FETCH_VARIANTS=0
# These two are only used by the LEGACY chunked Azure-STT fallback (when Vosk
# is unavailable). With Vosk enabled they are ignored.
WAKE_WORD_CHUNK_SECONDS=2.0
WAKE_WORD_COOLDOWN=0.1

# --- Vosk (offline streaming STT for wake-word detection) ---
# Two-letter code matching scripts/download_vosk_model.py MODEL_REGISTRY.
# Supported out of the box: ar, fr, en, es, de, it, tr, pt, ru, cn.
# Set to empty string to disable Vosk and fall back to the legacy Azure path.
VOSK_LANGUAGE=ar
# Where models are stored on disk (relative paths are anchored to the repo root).
VOSK_MODELS_DIR=models/vosk
# Read granularity for the recognizer (8000 bytes = 250 ms @ 16 kHz mono S16).
VOSK_CHUNK_BYTES=8000
# Auto-download the model on first boot if it is missing locally.
VOSK_AUTO_DOWNLOAD=1

# --- Continuous listener (VAD via sox; falls back to fixed duration) ---
LISTENER_MAX_SECONDS=15
LISTENER_SILENCE_DURATION=1.5
LISTENER_SILENCE_THRESHOLD_PCT=1.0
LISTENER_START_THRESHOLD_PCT=1.0
LISTENER_MIN_SPEECH_SECONDS=0.2

# --- Reconnaissance faciale (camera CSI -> backend /api/identify-face) ---
# Met le nom de la personne reconnue entre parentheses apres la transcription
# STT, ex: "quelle heure il est (salah)". A chaque wake-word une capture est
# faite en parallele du greeting; les follow-ups reutilisent le cache.
FACE_RECOGNITION_ENABLED=1
FACE_RECOGNITION_CACHE_SECONDS=60
FACE_RECOGNITION_FALLBACK=inconnu

# Camera CSI (rpicam-still / libcamera-still)
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_CAPTURE_TIMEOUT_MS=500

# --- Rotation auto vers le locuteur (DOA ReSpeaker -> moteurs M1/M3) ---
# Set to 0 to disable rotation entirely.
ROTATION_ENABLED=1
# Linear timing model (used unless ROTATION_LUT is set):
#   duration_s = max((|angle| - offset) / slope, min_duration)
# Mesurer slope ainsi : faire un 360° complet, slope = 360 / temps_pour_360.
# offset compense le temps de demarrage des moteurs (transitoire avant pleine vitesse).
ROTATION_SLOPE_DEG_PER_S=60
ROTATION_OFFSET_DEG=3.3
ROTATION_MIN_DURATION_S=0.05
ROTATION_SETTLE_S=0.4
# Angles plus petits que ce seuil = ignores (evite micro-corrections de bruit DOA)
ROTATION_DEADBAND_DEG=5
# Calibration "zero" : valeur DOA brute reportee quand un locuteur est exactement
# en face du robot. Mesurer une fois puis ne plus toucher.
ROTATION_FRONT_OFFSET_DEG=0
# Mettre a 1 si le mic 0° de votre ReSpeaker pointe vers l'arriere du robot
# (depend de l'orientation physique du module dans le chassis).
ROTATION_INVERT_DIRECTION=0
# Lookup table optionnel pour precision pro : "angle:duree,angle:duree,..."
# Mesurer la duree reelle a chaque angle avec un rapporteur, puis renseigner ici.
# Exemple (a remplacer par vos vraies mesures) :
# ROTATION_LUT=30:0.5,60:0.95,90:1.4,135:2.0,180:2.7
# ROTATION_LUT=
